# Production Environment Configuration
# For: https://e-library-portal.app

# Use relative /api path - NGINX will proxy this to the backend
# This avoids CORS issues completely
VITE_API_BASE_URL=/api

# API request timeout
VITE_API_TIMEOUT_MS=8000

# Internal user portal (same domain)
VITE_USER_PORTAL_URL=/user/dashboard

# Role mappings
VITE_ROLE_ID_READER="reader"
VITE_ROLE_ID_AUTHOR="author"
VITE_ROLE_ID_ADMIN="admin"
