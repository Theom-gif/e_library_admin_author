# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL=http://127.0.0.1:8000

# Backend API base URL used by Axios client (no trailing slash).
# IMPORTANT: Configure based on your deployment setup:
#
# LOCAL DEVELOPMENT (backend on port 8000):
# VITE_API_BASE_URL=http://localhost:8000
#
# PRODUCTION WITH NGINX PROXY (recommended):
# VITE_API_BASE_URL=/api
# Nginx config: location /api/ { proxy_pass https://elibrary.pncproject.site; }
#
# PRODUCTION DIRECT (without Nginx proxy):
# VITE_API_BASE_URL=https://your-backend-domain.com/api
#
# DEFAULT (if empty): /api - works seamlessly with Nginx reverse proxy
VITE_API_BASE_URL=/api

# Axios request timeout in milliseconds.
VITE_API_TIMEOUT_MS=8000

# Optional user portal URL. Leave as /user/dashboard to use internal user page.
# Set a full URL (e.g. http://localhost:3001/) only if you run a separate user app.
VITE_USER_PORTAL_URL=/user/dashboard

# Optional role_id mappings used by Register account type selector.
VITE_ROLE_ID_READER="reader"
VITE_ROLE_ID_AUTHOR="author"
VITE_ROLE_ID_ADMIN="admin"
